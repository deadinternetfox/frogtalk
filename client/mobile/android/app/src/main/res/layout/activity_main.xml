<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/frog_loading_bg">

    <!-- WebView container - WebView added programmatically -->
    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Loading screen - shown while WebView initialises -->
    <LinearLayout
        android:id="@+id/loading_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/loading_bg"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐸"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="FrogTalk"
            android:textColor="@color/frog_green"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Connecting to the pond…"
            android:textColor="@color/frog_loading_text"
            android:textSize="13sp" />

        <ProgressBar
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="22dp"
            android:indeterminateTint="@color/frog_green" />
    </LinearLayout>

    <!-- Error screen - shown if WebView fails to load -->
    <LinearLayout
        android:id="@+id/error_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/loading_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐸"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Something went wrong"
            android:textColor="@color/frog_green"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/error_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Could not start the app.\nPlease update Android System WebView\nfrom the Play Store and try again."
            android:textColor="@color/frog_loading_text"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/frog_green"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:text="Retry"
            android:textColor="#000000"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_open_browser"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/frog_loading_surface"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:text="Open in Browser"
            android:textColor="#CCCCCC" />
    </LinearLayout>

</FrameLayout>
