# ──────────────────────────────────────────────────────────────
#  FrogTalk Node — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── GIF provider (KLIPY preferred; Tenor sunsets 2026-06-30) ───
# Sign up at https://partner.klipy.com → API Keys, then paste the platform
# key here. Without it the /media/gifs/* endpoints respond 503.
KLIPY_API_KEY=
# Optional override (default https://api.klipy.com)
KLIPY_API_BASE=
# Legacy Tenor key — only used as a fallback if KLIPY is unset / errors.
# Google is shutting Tenor down on 2026-06-30; remove once KLIPY is live.
TENOR_API_KEY=

# Admin account password (auto-created user "admin" on first run).
# HIGH-5: leave EMPTY for production. When empty, the bootstrap path in
# database.py generates a one-shot random password and logs it once on
# first boot — that's the value to use to log in and immediately rotate.
# Setting this to the historical "change_me_now_123!" default is treated
# as if it were empty so an unrotated stale .env can't be exploited.
ADMIN_PASSWORD=

# Comma-separated list of allowed CORS origins (use * for dev only)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Path to SQLite database file
DB_PATH=data/frogtalk.db

# ── Server Management WebUI ──────────────────────────────────
# 0 = disabled (recommended default), 1 = enabled
FROGTALK_SERVER_WEBUI_ENABLED=0
# Dedicated operator login (do not reuse public app creds)
FROGTALK_SERVER_WEBUI_USER=serveradmin
FROGTALK_SERVER_WEBUI_PASSWORD=change_server_webui_password
# Session lifetime in seconds (300-86400)
FROGTALK_SERVER_WEBUI_SESSION_TTL_SEC=3600
# Set to 1 behind HTTPS so secure cookies are required
FROGTALK_SERVER_WEBUI_COOKIE_SECURE=0

# Official server directory (auto-synced by the app + node_federation_join.sh)
FROGTALK_OFFICIAL_DIRECTORY_URL=https://frogtalk.xyz/api/network/servers
# Optional: how often to sync official directory
FROGTALK_OFFICIAL_DIRECTORY_SYNC_INTERVAL_SEC=900

# ── SSH Deploy ─────────────────────────────────────────────────
# Remote server details for deployment
SSH_HOST=your.server.ip.or.hostname
SSH_PORT=22
SSH_USER=deploy
# Path to your private key (leave blank to use default ~/.ssh/id_rsa)
SSH_KEY_PATH=~/.ssh/id_rsa

# Remote directory where FrogChat is deployed
REMOTE_DIR=/opt/frogtalk

# ── TLS / Reverse Proxy ────────────────────────────────────────
# If running behind nginx/caddy, set this to the public URL
PUBLIC_URL=https://chat.yourdomain.com

# ── SEO / IndexNow ─────────────────────────────────────────────
# Public canonical site URL used in robots.txt + sitemap output.
FROGTALK_SITE_URL=https://yourdomain.com
# IndexNow API key (generate with: python -c "import secrets;print(secrets.token_hex(16))")
# Submitting URLs to https://api.indexnow.org/indexnow with this key triggers
# instant re-crawl by Bing, Yandex, Seznam, Naver, and Yep.
# The server will serve the proof file at /<key>.txt automatically.
FROGTALK_INDEXNOW_KEY=

# Absolute path to the imageboard's threads.json for sitemap-board.xml generation.
# Default: /opt/frogtalk/node/board/board_data/threads.json
FROGTALK_BOARD_DATA_PATH=

# ── iOS App (TestFlight + APNs/PushKit) ────────────────────────
# Public TestFlight or App Store link for /download/ios redirect.
IOS_DOWNLOAD_URL=
# Apple Developer 10-char Team ID (used in apple-app-site-association).
APPLE_TEAM_ID=
# iOS bundle id (must match Xcode project + APNs key topic).
APNS_BUNDLE_ID=xyz.frogtalk.app
# APNs auth key (.p8) downloaded from developer.apple.com → Keys.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=/opt/frogtalk/secrets/apns.p8
# 1 = use api.sandbox.push.apple.com (development builds), 0 = production.
APNS_USE_SANDBOX=0

# ── Android FCM (Firebase Cloud Messaging) ─────────────────────
# Path to a Firebase service-account JSON downloaded from
#   https://console.firebase.google.com → Project settings → Service accounts
#   → Generate new private key.
# WITHOUT THIS, no Android device receives FCM notifications (calls,
# DMs, friend requests). The push.py module silently no-ops every
# Android send if firebase-admin can't initialize. The project must
# match client/mobile/android/app/google-services.json's project_id.
# Mode 600, owned by whichever user runs the frogtalk service.
FIREBASE_SERVICE_ACCOUNT_JSON=/opt/frogtalk/secrets/firebase-service-account.json
# Optional: explicitly pin the Firebase project id. If unset, it is
# read from the service-account JSON. Set this only if you have
# multiple Firebase projects sharing one service account.
FIREBASE_PROJECT_ID=

# ── Federation (multi-node sync) ───────────────────────────────
FROGTALK_FEDERATION_ENABLED=1
# Shared bearer for legacy peers. Leave empty when every node uses Ed25519
# signed push (dual/signed mode). If empty, outbox still pushes when the
# local signing key is present — receivers must pin your pubkey.
FROGTALK_FEDERATION_TOKEN=
# dual (default) | signed | legacy — prefer dual or signed in production.
FROGTALK_FEDERATION_AUTH_MODE=dual
# 1 = reject unsigned federation events (recommended once pubkeys are pinned).
FROGTALK_FEDERATION_REQUIRE_SIGS=1
# Cross-node WebRTC signaling (call.* / voice.* federation events)
FROGTALK_FEDERATION_CALLS_ENABLED=0
# Background inbox/outbox poll intervals (seconds). Defaults: 8 idle, 2 busy.
FROGTALK_FEDERATION_INBOX_IDLE_SEC=8
FROGTALK_FEDERATION_INBOX_BUSY_SEC=2
FROGTALK_FEDERATION_OUTBOX_IDLE_SEC=8
FROGTALK_FEDERATION_OUTBOX_BUSY_SEC=2
# Per-node STUN/TURN (advertised on /api/network/status and ice-config)
FROGTALK_TURN_URLS=stun:stun.l.google.com:19302,turn:your.turn.host:3478
FROGTALK_TURN_USERNAME=
FROGTALK_TURN_CREDENTIAL=
# Channel voice SFU v2 (off = federated mesh v1)
FROGTALK_VOICE_SFU=0
# Tor mirror: SOCKS proxy for outbound peer fetches (default tor port).
FROGTALK_TOR_SOCKS_PROXY=socks5://127.0.0.1:9050
FROGTALK_TOR_ENABLED=0
FROGTALK_ONION_URL=

# ── Fallow (optional JS analysis / desktop runtime coverage) ───
# Static audit: npx fallow (see .fallowrc.json). Runtime beacon applies
# only to the Electron desktop main process (Node), not python main.py.
# Create a key at https://fallow.cloud (prefix fallow_live_k1_, shown once).
BEACON_API_KEY=
FALLOW_PROJECT_ID=deadinternetfox/frogtalk
# Optional commit label sent with coverage batches (CI: git rev-parse HEAD).
GIT_SHA=
