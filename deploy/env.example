# ──────────────────────────────────────────────────────────────
#  FrogChat — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# Admin account password (auto-created user "admin" on first run)
ADMIN_PASSWORD=change_me_now_123!

# Comma-separated list of allowed CORS origins (use * for dev only)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Path to SQLite database file
DB_PATH=data/frogtalk.db

# ── Server Management WebUI ──────────────────────────────────
# 0 = disabled (recommended default), 1 = enabled
FROGTALK_SERVER_WEBUI_ENABLED=0
# Dedicated operator login (do not reuse public app creds)
FROGTALK_SERVER_WEBUI_USER=serveradmin
FROGTALK_SERVER_WEBUI_PASSWORD=change_server_webui_password
# Session lifetime in seconds (300-86400)
FROGTALK_SERVER_WEBUI_SESSION_TTL_SEC=3600
# Set to 1 behind HTTPS so secure cookies are required
FROGTALK_SERVER_WEBUI_COOKIE_SECURE=0

# Optional: official server directory feed JSON URL
FROGTALK_OFFICIAL_DIRECTORY_URL=
# Optional: how often to sync official directory
FROGTALK_OFFICIAL_DIRECTORY_SYNC_INTERVAL_SEC=900

# ── SSH Deploy ─────────────────────────────────────────────────
# Remote server details for deployment
SSH_HOST=your.server.ip.or.hostname
SSH_PORT=22
SSH_USER=deploy
# Path to your private key (leave blank to use default ~/.ssh/id_rsa)
SSH_KEY_PATH=~/.ssh/id_rsa

# Remote directory where FrogChat is deployed
REMOTE_DIR=/opt/frogtalk

# ── TLS / Reverse Proxy ────────────────────────────────────────
# If running behind nginx/caddy, set this to the public URL
PUBLIC_URL=https://chat.yourdomain.com

# ── SEO / IndexNow ─────────────────────────────────────────────
# Public canonical site URL used in robots.txt + sitemap output.
FROGTALK_SITE_URL=https://yourdomain.com
# IndexNow API key (generate with: python -c "import secrets;print(secrets.token_hex(16))")
# Submitting URLs to https://api.indexnow.org/indexnow with this key triggers
# instant re-crawl by Bing, Yandex, Seznam, Naver, and Yep.
# The server will serve the proof file at /<key>.txt automatically.
FROGTALK_INDEXNOW_KEY=

# ── iOS App (TestFlight + APNs/PushKit) ────────────────────────
# Public TestFlight or App Store link for /download/ios redirect.
IOS_DOWNLOAD_URL=
# Apple Developer 10-char Team ID (used in apple-app-site-association).
APPLE_TEAM_ID=
# iOS bundle id (must match Xcode project + APNs key topic).
APNS_BUNDLE_ID=xyz.frogtalk.app
# APNs auth key (.p8) downloaded from developer.apple.com → Keys.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=/opt/frogtalk/secrets/apns.p8
# 1 = use api.sandbox.push.apple.com (development builds), 0 = production.
APNS_USE_SANDBOX=0
