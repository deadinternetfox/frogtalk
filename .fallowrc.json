{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "node/static/index.html",
    "node/static/server_admin.html",
    "node/static/sw.js",
    "node/static/vendor/qr/jsQR.js",
    "node/static/vendor/qr/qrcode.min.js",
    "client/desktop/app/main.js",
    "client/desktop/app/preload.js"
  ],
  "ignorePatterns": [
    "node/static/vendor/**",
    "**/*.min.js"
  ],
  "ignoreDependencies": ["electron", "electron-builder"],
  "production": true,
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unresolved-imports": "warn"
  },
  "duplicates": {
    "minLines": 8,
    "minTokens": 40
  }
}
