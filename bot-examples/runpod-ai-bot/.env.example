# FrogTalk server (no trailing slash)
FROGTALK_SERVER=https://frogtalk.xyz

# bot_… token issued in Settings → Developer → Bots → + Create Bot
FROGTALK_BOT_TOKEN=bot_replace_me

# The handle the bot was registered with (used to detect @mentions).
# Must match the bot's `name` exactly, case-insensitive.
FROGTALK_BOT_NAME=runpod-ai

# Comma-separated channels to listen in. Leave empty (the default) to
# auto-discover the bot's installed channels via
# GET /api/external/me/channels — that way an owner can add the bot to
# a new channel from Settings → Bots and it picks up on the next refresh
# without a restart.
FROGTALK_CHANNELS=

# Force auto-discovery on even when FROGTALK_CHANNELS is set (use this
# to keep a pinned list as the *minimum* and merge in any new
# installations). Accepts 1 / true / yes / on.
FROGTALK_AUTO_CHANNELS=1

# Polling interval per channel, seconds.
POLL_INTERVAL=2.0

# How many recent messages to include as conversational context.
MAX_CONTEXT=8

# --- RunPod ---
# Endpoint id (the bit between /v2/ and /run on the RunPod console URL).
RUNPOD_ENDPOINT_ID=9xffis4xtq1uc5
# rpa_… key (Settings → API Keys on the RunPod console).
RUNPOD_API_KEY=rpa_replace_me

# --- Optional: profile sync (--update-profile mode) ---
# A FrogTalk *user* session token. Only needed if you want to update
# the bot's avatar/description from the CLI; otherwise leave blank and
# edit the bot in the app instead.
FROGTALK_USER_SESSION=
