# Maintainer: FrogTalk <support@frogtalk.xyz>
# AUR: https://aur.archlinux.org/packages/frogtalk-bin
# Upstream: https://github.com/deadinternetfox/frogtalk
#
# Prebuilt .deb repackaged for Arch (system electron41).
# After cutting a GitHub release, refresh sums:
#   bash packaging/aur/update-frogtalk-bin.sh

pkgname=frogtalk-bin
_pkgname=FrogTalk
pkgver=1.5.3
_electronversion=41
pkgrel=1
# Note: GitHub must host frogtalk_${pkgver}_amd64.deb — run
# packaging/aur/update-frogtalk-bin.sh after `build-linux-release.sh` + release upload.
pkgdesc="Federated E2E chat — desktop client (prebuilt, system Electron)"
arch=('x86_64')
url="https://frogtalk.xyz/"
_ghurl="https://github.com/deadinternetfox/frogtalk"
license=('MIT')
conflicts=('frogtalk')
provides=('frogtalk')
depends=("electron${_electronversion}")
options=('!emptydirs' '!strip')
source=(
  "${pkgname%-bin}-${pkgver}.deb::${_ghurl}/releases/download/v${pkgver}/${pkgname%-bin}_${pkgver}_amd64.deb"
  "LICENSE-${pkgver}::${_ghurl}/raw/v${pkgver}/LICENSE"
  "${pkgname%-bin}.sh"
)
# Run packaging/aur/update-frogtalk-bin.sh after publishing frogtalk_${pkgver}_amd64.deb
sha256sums=('1a53f72d51fd8bc15d1d59023bf2d2bbc66694fffd2be929f819b6f3ab6753af'
            '9a919bf3c59d886d7802566024b2eb9b438660d148faad5e6ffcd85afee00380'
            'fdd7b7bffafacbf0e9c3c0437d45e00d46979a004ddb0930c77ca55342a0030b')

_check_electron_version() {
  local _app_dir _main_exe _elec_ver
  _app_dir=$(find "${srcdir}" -type f -name 'resources.pak' -exec dirname {} + | head -n 1)
  _main_exe=''
  if [[ -n "${_app_dir}" ]]; then
    _main_exe=$(find "${_app_dir}" -maxdepth 1 -type f -executable -printf '%s %p\n' 2>/dev/null | sort -nr | head -n 1 | cut -d' ' -f2-)
  fi
  if [[ -n "${_main_exe}" ]]; then
    _elec_ver=$(strings "${_main_exe}" 2>/dev/null | grep '^Chrome/[0-9.]* Electron/[0-9]' | cut -d'/' -f3 | cut -d'.' -f1 | head -n 1)
    if [[ -n "${_elec_ver}" && "${_elec_ver}" != "${_electronversion}" ]]; then
      printf '\033[1;31mWarning: Electron %s in .deb, expected %s\033[0m\n' "${_elec_ver}" "${_electronversion}" >&2
    fi
  fi
}

prepare() {
  sed -i -e "
    s/@electronversion@/${_electronversion}/g
    s/@appname@/${pkgname%-bin}/g
    s/@runname@/app/g
    s/@cfgdirname@/${_pkgname}/g
  " "${srcdir}/${pkgname%-bin}.sh"
  bsdtar -xf "${srcdir}/data."*
  _check_electron_version
  sed -i "s|/opt/${_pkgname}/||g" "${srcdir}/usr/share/applications/${pkgname%-bin}.desktop"
}

package() {
  install -Dm755 "${srcdir}/${pkgname%-bin}.sh" "${pkgdir}/usr/bin/${pkgname%-bin}"
  install -dm755 "${pkgdir}/usr/lib/${pkgname%-bin}"
  local _app_dir
  _app_dir=$(find "${srcdir}" -type f -name 'resources.pak' -exec dirname {} + | head -n 1)
  cp -a "${_app_dir}/resources/." "${pkgdir}/usr/lib/${pkgname%-bin}/"
  find "${srcdir}" -type f \( -name '*.png' -o -name '*.svg' \) -path '*share/icons/*' | while read -r _i; do
    local _extension="${_i##*.}"
    local _icon_path="${_i#*share/icons/}"
    install -Dm644 "${_i}" "${pkgdir}/usr/share/icons/$(dirname "${_icon_path}")/${pkgname%-bin}.${_extension}"
  done
  install -Dm644 "${srcdir}/usr/share/applications/${pkgname%-bin}.desktop" "${pkgdir}/usr/share/applications/${pkgname%-bin}.desktop"
  install -Dm644 "${srcdir}/LICENSE-${pkgver}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
